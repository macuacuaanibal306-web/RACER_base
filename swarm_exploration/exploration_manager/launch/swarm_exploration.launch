  <!-- intent boundary reset -->
  <param name="intent_prediction/boundary_hit_time_thresh" value="0.5" />
  <param name="intent_prediction/boundary_keep_recent_time" value="0.4" />
  <param name="intent_prediction/boundary_keep_recent_samples" value="3" />
  <param name="intent_prediction/boundary_min_speed" value="0.15" />
  <param name="intent_prediction/speed_avg_time" value="3.0" />
  <param name="intent_prediction/speed_min_dt" value="0.05" />
  <param name="intent_prediction/pred_horizon" value="3.0" />
  <param name="intent_prediction/enable_speed_vis" value="true" />
  <param name="intent_prediction/speed_vis_scale" value="1.5" />
  <param name="intent_prediction/speed_vis_min_len" value="0.25" />
  <param name="intent_prediction/speed_vis_max_len" value="3.0" />

  <!-- Leader-based rendezvous manager. In this two-drone debug version, drone 1 is fixed as the cluster leader/owner that computes and publishes the rendezvous region. -->
  <include file="$(find rendezvous_manager)/launch/two_drone_rendezvous.launch">
    <arg name="enable" value="true"/>
    <arg name="self_drone_id" value="1"/>
    <arg name="leader_drone_id" value="1"/>
    <arg name="compute_only_if_leader" value="true"/>
    <arg name="drone_id_1" value="1"/>
    <arg name="drone_id_2" value="2"/>
    <arg name="comm_range" value="$(arg comm_range)"/>
  </include>

</launch>
